# map SSL verification result
map $ssl_client_verify $no_cert {
    SUCCESS 0;
    default 1;
}

# WebSocket connection upgrade mapping
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# log format
log_format gitlab_ssl '$remote_addr - $remote_user [$time_local] '
                      '"$request" $status $body_bytes_sent '
                      '"$http_referer" "$http_user_agent" '
                      'SSL_VERIFY=$ssl_client_verify '
                      'SSL_SUBJECT="$ssl_client_s_dn" '
                      'SSL_ISSUER="$ssl_client_i_dn"';

upstream gitlab-workhorse {
    server 127.0.0.1:8181 fail_timeout=0;
}

server {
    listen 443 ssl;
    server_name gitlab.zt.devsecops.local;
    
    # SSL certificates
    ssl_certificate /etc/ssl/certs/gitlab.crt;
    ssl_certificate_key /etc/ssl/private/gitlab.key;
    
    # Optional client cert
    ssl_client_certificate /etc/gitlab/zt-root-ca.pem;
    ssl_verify_client optional;
    ssl_verify_depth 2;
    
    access_log /var/log/nginx/gitlab_ssl_access.log gitlab_ssl;
    error_log  /var/log/nginx/gitlab_ssl_error.log warn;
    
    # Increase buffer sizes
    client_max_body_size 250m;
    proxy_buffer_size 128k;
    proxy_buffers 4 256k;
    proxy_busy_buffers_size 256k;
    
    # Location for all ip
    location = /no-cert {
        allow all;  
        default_type text/html;
        return 200 '<!DOCTYPE html>
<html>
<head>
    <title>Certificate Required</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 50px; }
        h1 { color: #d9534f; }
    </style>
</head>
<body>
    <h1>Client Certificate Required</h1>
    <p>You need a valid client certificate to access this GitLab instance.</p>
    <p>Please contact your administrator for assistance.</p>
</body>
</html>';
    }
    
    # Main location
    location / {
 	# check ip
	deny 192.168.20.0/24;
	deny 10.0.1.0/24;
	allow 10.0.2.0/24;
	allow all;
        
        # Check cert
        # Dùng error_page instead of ip
        error_page 495 = @no_cert_redirect;
        if ($no_cert) {
            return 495;  # Custom error code
        }
        
        proxy_pass http://gitlab-workhorse;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Ssl on;
        
        # Pass client cert info
        proxy_set_header X-SSL-Client-Verify $ssl_client_verify;
        proxy_set_header X-SSL-Client-S-DN $ssl_client_s_dn;
        proxy_set_header X-SSL-Client-I-DN $ssl_client_i_dn;
        
        # GitLab specific headers
        proxy_set_header X-Forwarded-Host $http_host;
        proxy_set_header X-Forwarded-Server $host;
        
        proxy_read_timeout 3600;
        proxy_connect_timeout 300;
        proxy_redirect off;
        
        # WebSocket support
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        
        # Buffering settings
        proxy_request_buffering off;
    }
    
    # Named location cho redirect
    location @no_cert_redirect {
        return 302 /no-cert;
    }
}
